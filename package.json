{
  "name": "aceengineer-website",
  "version": "1.0.0",
  "scripts": {
    "build": "node build.js",
    "serve": "npx serve dist",
    "lint:copy": "node scripts/lint-copy.js",
    "validate:capabilities": "node scripts/validate-capabilities.js",
    "validate:capabilities:online": "node scripts/verify-capabilities-online.js",
    "validate:registry": "npm run validate:capabilities && npm run validate:capabilities:online",
    "scaffold:capability": "node scripts/scaffold-capability-entry.js",
    "refresh:hf": "node scripts/refresh-hf-data.js",
    "refresh:sloshing": "node scripts/refresh-sloshing-data.js",
    "publish:sloshing-enrichment": "node scripts/publish-sloshing-enrichment.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "projects": [
      {
        "displayName": "node",
        "testMatch": ["<rootDir>/tests/js/build.test.js"]
      },
      {
        "displayName": "copy-lint",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/copy-lint.test.js"]
      },
      {
        "displayName": "capabilities-registry",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/capabilities-registry.test.js"]
      },
      {
        "displayName": "hf-fetch",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/hf-fetch.test.js"]
      },
      {
        "displayName": "sloshing-build",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/sloshing-build.test.js"]
      },
      {
        "displayName": "sloshing-refresh",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/sloshing-refresh.test.js"]
      },
      {
        "displayName": "sloshing-reports",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/js/sloshing-reports.test.js"]
      },
      {
        "displayName": "capabilities-online",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/capabilities-online.test.js"]
      },
      {
        "displayName": "render-capabilities",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/render-capabilities.test.js"]
      },
      {
        "displayName": "capabilities-refresh",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/js/capabilities-refresh.test.js"]
      },
      {
        "displayName": "jsdom",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/js/navbar-toggle.test.js"]
      },
      {
        "displayName": "hse-dashboard",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/js/hse-risk-dashboard.test.js"]
      },
      {
        "displayName": "npv-calculator",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/npv-calculator.test.js"]
      },
      {
        "displayName": "obs-calculator",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/obs-calculator.test.js"]
      },
      {
        "displayName": "wall-thickness",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/wall-thickness.test.js"]
      },
      {
        "displayName": "mooring-fatigue",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/mooring-fatigue.test.js"]
      },
      {
        "displayName": "decline-curve",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/js/decline-curve.test.js"]
      },
      {
        "displayName": "demo-links",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/js/demo-links.test.js"]
      },
      {
        "displayName": "cta-tracking",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/js/cta-tracking.test.js"]
      }
    ],
    "collectCoverageFrom": [
      "build.js",
      "scripts/hf-fetch.js",
      "scripts/render-capabilities.js",
      "scripts/verify-capabilities-online.js",
      "scripts/refresh-sloshing-data.js",
      "assets/js/sloshing-reports.js",
      "assets/js/navbar-toggle.js",
      "assets/js/cta-tracking.js",
      "assets/js/capabilities-refresh.js",
      "assets/js/npv-calculator-engine.js",
      "assets/js/mooring-fatigue-engine.js",
      "assets/js/decline-curve-engine.js",
      "demos/hse-risk-dashboard-data.js"
    ]
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "posthtml": "^0.16.6",
    "posthtml-expressions": "^1.11.3",
    "posthtml-include": "^2.0.1",
    "purgecss": "^8.0.0"
  }
}
